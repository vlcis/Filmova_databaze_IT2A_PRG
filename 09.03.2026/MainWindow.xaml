<Window x:Class="_09._03._2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_09._03._2026"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Label Content="Search:"/>
            <TextBox Width="200" Margin="5 0"/>

            <Label Content="Genre:" Margin="20 0 0 0"/>
            <ComboBox Width="150">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Action"/>
                <ComboBoxItem Content="Drama"/>
                <ComboBoxItem Content="Comedy"/>
                <ComboBoxItem Content="Sci-Fi"/>
            </ComboBox>
        </StackPanel>

        <!-- Movie table -->
        <DataGrid Grid.Row="1" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}"/>
                <DataGridTextColumn Header="Year" Binding="{Binding Year}"/>
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre}"/>
                <DataGridTextColumn Header="Length (min)" Binding="{Binding Length}"/>
                <DataGridTextColumn Header="IMDb" Binding="{Binding Imdb}"/>
                <DataGridTextColumn Header="ČSFD" Binding="{Binding Csfd}"/>
                <DataGridTextColumn Header="Rotten Tomatoes" Binding="{Binding Rotten}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add Movie" Width="100" Margin="5"/>
            <Button Content="Edit Movie" Width="100" Margin="5"/>
            <Button Content="Delete Movie" Width="100" Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
